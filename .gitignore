# ============================================
# Скомпилированные и временные файлы C/C++
# ============================================
*.out          # Исполняемые файлы (a.out)
*.o            # Объектные файлы
*.obj          # Объектные файлы (Windows)
*.exe          # Исполняемые файлы (Windows)
*.dll          # Динамические библиотеки
*.so           # Динамические библиотеки (Linux)
*.dylib        # Динамические библиотеки (macOS)
*.lib          # Статические библиотеки
*.a            # Статические библиотеки
*.pch          # Precompiled headers
*.gch          # Precompiled headers (GCC)
*.dep          # Файлы зависимостей
*.log          # Логи

# Папки сборки
build/
cmake-build-*/
out/
Debug/
Release/

# Ninja build files
build.ninja
.ninja_deps
.ninja_log
rules.ninja

# CTest (тесты CMake)
Testing/
DartConfiguration.tcl

# ============================================
# Файлы генерации и анализа кода
# ============================================
compile_commands.json    # База данных компиляции для clangd/IDE

# ============================================
# Настройки IDE и редакторов
# ============================================

# VS Code - игнорируем только локальные настройки
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/c_cpp_properties.json

# Но НЕ игнорируем рекомендуемые расширения (если создадите)
# !.vscode/extensions.json

# CLion / JetBrains IDE
.idea/
*.iml
*.ipr
*.iws
cmake-build-*/

# Visual Studio
.vs/
*.suo
*.user
*.sdf
*.opensdf

# ============================================
# Системные файлы ОС
# ============================================
.DS_Store        # macOS
Thumbs.db        # Windows
desktop.ini      # Windows
*~               # Временные файлы Linux (backup)
*.swp            # Vim swap files

# ============================================
# Прочее
# ============================================
*.bak            # Бэкапы
*.tmp            # Временные файлы